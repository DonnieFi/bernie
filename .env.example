# Bernie environment template — copy to .env and fill in your secrets.
#   cp .env.example .env
# Never commit .env. See docs/reference/environment.md for details.

# ── Required ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
ANTHROPIC_API_KEY=

# Shared secret for cross-container writes (generate: openssl rand -hex 32)
# Must be identical on bernie-discord, bernie-api, and bernie-cognition.
INTERNAL_POST_SECRET=

# ── Google OAuth (container paths; host files live in ./credentials/) ───────
GOOGLE_CREDENTIALS_FILE=/credentials/credentials.json
GOOGLE_TOKEN_FILE=/credentials/token.json
GMAIL_TOKEN_FILE=/credentials/gmail_token.json

# Host-side one-time OAuth (optional — scripts print the redirect URL; set only if port is busy)
# CREDENTIALS_DIR=
# GOOGLE_OAUTH_PORT=
# GMAIL_OAUTH_PORT=

# ── LLM providers ───────────────────────────────────────────────────────────
# Anthropic direct — claude-* models (see ANTHROPIC_API_KEY above)

# OpenRouter — or-* models when openrouter_direct is enabled in config.json
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_LITE=

# LiteLLM proxy — litellm_base_url in config.json + proxy-registered models
LTE_LLM_MASTER_KEY=

# ── Integrations & tools ─────────────────────────────────────────────────────
SPOON_API_KEY=
TOMORROW_WEATHER_API=
OURA_TOKEN=
FLIGHT_AERO_KEY=
UNIFI_KEY=

# Home Assistant token fallback (normally set in config.json → home_assistant.token)
HOME_ASSISTANT_KEY=

# Frigate MQTT (optional — if broker requires auth)
MQTT_USER=
MQTT_PASSWORD=

# ── Web dashboard API (optional — PIN auth still required in config.json) ───
BERNIE_API_TOKEN=

# ── Observability (optional — tracing disabled when unset) ─────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ── Advanced / split deploy (optional — defaults work for standard compose) ──
# INTERNAL_COGNITION_URL=http://bernie-cognition:9000
# INTERNAL_DISCORD_URL=http://bernie-discord:9000
# CONFIG_PATH=/app/config.json
# BERNIE_DB_BACKUP_DIR=/data/backups

# ── Container runtime ────────────────────────────────────────────────────────
# TZ=America/Halifax
